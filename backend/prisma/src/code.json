{
  "name": "messenger-automation-backend",
  "version": "1.0.0",
  "description": "Facebook Messenger Automation Platform - Backend API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.20",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.20",
    "@nestjs/platform-socket.io": "^11.1.20",
    "@nestjs/throttler": "^7.0.1",
    "@nestjs/websockets": "^11.1.20",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/swagger": "^11.1.2",
    "@prisma/adapter-pg": "^7.3.0",
    "prisma": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^5.0.0",
    "passport-google-oauth20": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "socket.io": "^4.8.1",
    "helmet": "^8.0.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.1",
    "ioredis": "^5.5.0",
    "dayjs": "^1.11.13",
    "nanoid": "^5.1.0",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.4",
    "nodemailer": "^6.10.0",
    "handlebars": "^4.7.8",
    "axios": "^1.7.9",
    "multer": "^2.0.0",
    "sharp": "^0.33.5",
    "express-rate-limit": "^7.5.0",
    "winston": "^3.17.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.3",
    "@nestjs/testing": "^11.1.20",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.24",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
